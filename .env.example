# Copy this file to `.env` and adjust values. `.env` is git-ignored.
# Every variable here is validated at boot by packages/config.

NODE_ENV=development
LOG_LEVEL=info

# API server
API_PORT=3000

# PostgreSQL (docker-compose reads these to create the container;
# DATABASE_URL is what our apps use to connect to it)
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=dev-only-change-me
POSTGRES_DB=job_scheduler
POSTGRES_PORT=5432
DATABASE_URL=postgresql://scheduler:dev-only-change-me@localhost:5432/job_scheduler

# Auth. Generate a real value for .env with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-value-min-32-chars
JWT_EXPIRES_IN=7d
